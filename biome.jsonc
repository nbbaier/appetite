{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["ultracite/biome/core", "ultracite/biome/react"],
  "files": {
    "ignoreUnknown": false,
    "includes": ["!dist", "!public/**/*.svg"]
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "linter": {
    "rules": {
      "style": {
        // Existing files use PascalCase components / camelCase modules.
        // Disabled for now rather than renaming the whole tree.
        "useFilenamingConvention": "off"
      }
    }
  },
  "overrides": [
    {
      // Supabase edge functions run on Deno, not the browser.
      "includes": ["supabase/functions/**"],
      "javascript": {
        "globals": ["Deno"]
      }
    },
    {
      // Vendored shadcn/ui primitives follow Radix's `import * as X` convention.
      "includes": ["src/components/ui/**"],
      "linter": {
        "rules": {
          "performance": {
            "noNamespaceImport": "off"
          }
        }
      }
    },
    {
      // Test-only relaxations:
      // - useTopLevelRegex: inline regex assertions (toMatch(/.../)) are throwaway.
      // - useAwait: `act(async () => {})` requires an async callback with
      //   nothing to await directly (idiomatic React Testing Library).
      // - noNamespaceImport: `import * as Mod` is needed for vi.spyOn(Mod, ...).
      "includes": ["**/*.test.{ts,tsx}"],
      "linter": {
        "rules": {
          "performance": {
            "useTopLevelRegex": "off",
            "noNamespaceImport": "off"
          },
          "suspicious": {
            "useAwait": "off"
          }
        }
      }
    }
  ]
}
